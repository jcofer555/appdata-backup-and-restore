<?php
/*
 * AppData Backup Plugin for Unraid
 * WebUI Page
 */

$plugin      = 'appdata-backup';
$configDir   = "/boot/config/plugins/$plugin";
$configFile  = "$configDir/config.cfg";
$logDir      = "/tmp/$plugin";
$lockFile    = "$logDir/backup.lock";
$logFile     = "$logDir/backup.log";

// Load config with defaults
$defaults = [
    'BACKUP_DEST'        => '/mnt/user/backups/appdata',
    'APPDATA_SRC'        => '/mnt/user/appdata',
    'STOP_CONTAINERS'    => 'yes',
    'COMPRESS'           => 'yes',
    'COMPRESSION_TYPE'   => 'gz',
    'RETENTION_DAYS'     => '7',
    'RETENTION_COUNT'    => '5',
    'SCHEDULED_ENABLE'   => 'no',
    'CRON_SCHEDULE'      => '0 3 * * *',
    'NOTIFY_ENABLE'      => 'yes',
    'NOTIFY_LEVEL'       => 'both',
    'EXCLUDE_CONTAINERS' => '',
    'INCLUDE_CONTAINERS' => '',
    'VERIFY_BACKUP'      => 'yes',
    'BACKUP_VMDISKS'     => 'no',
    'EXTRA_FOLDERS'      => '',
    'PRE_SCRIPT'         => '',
    'POST_SCRIPT'        => '',
    'RCLONE_ENABLE'      => 'no',
    'RCLONE_REMOTE'      => '',
    'RCLONE_PATH'        => '',
];

$cfg = $defaults;
if (file_exists($configFile)) {
    $lines = file($configFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        if (strpos($line, '=') !== false && $line[0] !== '#') {
            [$k, $v] = explode('=', $line, 2);
            $cfg[trim($k)] = trim($v, " \t\n\r\0\x0B\"'");
        }
    }
}

// Get running docker containers
$containers = [];
exec("docker ps --format '{{.Names}}' 2>/dev/null | sort", $containers);

// Get all docker containers
$allContainers = [];
exec("docker ps -a --format '{{.Names}}' 2>/dev/null | sort", $allContainers);

// Check if backup is running
$isRunning = file_exists($lockFile);

// Last backup info
$lastBackupFile = "$logDir/last_backup.txt";
$lastBackup     = file_exists($lastBackupFile) ? trim(file_get_contents($lastBackupFile)) : 'Never';

// Backup size info
$backupSizeFile = "$logDir/backup_size.txt";
$backupSize     = file_exists($backupSizeFile) ? trim(file_get_contents($backupSizeFile)) : 'Unknown';

// Count existing backups
$backupCount = 0;
if (is_dir($cfg['BACKUP_DEST'])) {
    $backupFolders = glob($cfg['BACKUP_DEST'] . '/appdata_backup_*', GLOB_ONLYDIR);
    $backupCount   = count($backupFolders);
}
?>

